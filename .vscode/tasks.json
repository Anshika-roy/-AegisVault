{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start local web server (5500)",
      "type": "shell",
      "command": "py",
      "args": [
        "-3",
        "-m",
        "http.server",
        "5500",
        "--bind",
        "127.0.0.1"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "Serving HTTP on .*127.0.0.1.*port 5500"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
