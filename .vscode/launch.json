{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Run App (Edge + Localhost - Register First)",
            "type": "msedge",
            "request": "launch",
            "url": "http://127.0.0.1:5500/register.html",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start local web server (5500)"
        },
        {
            "name": "Run Register (Edge + Localhost)",
            "type": "msedge",
            "request": "launch",
            "url": "http://127.0.0.1:5500/register.html",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start local web server (5500)"
        },
        {
            "name": "Run Login (Edge + Localhost)",
            "type": "msedge",
            "request": "launch",
            "url": "http://127.0.0.1:5500/login.html",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start local web server (5500)"
        },
        {
            "name": "Attach to Chrome",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Launch Chrome (Register First)",
            "request": "launch",
            "type": "chrome",
            "url": "http://127.0.0.1:5500/register.html",
            "preLaunchTask": "Start local web server (5500)",
            "webRoot": "${workspaceFolder}"
        }
    ]
}